# --- Core ---
APP_NAME=EduNova AI
ENVIRONMENT=development
DEBUG=true
PORT=8000

# --- Security ---
SECRET_KEY=replace-with-a-strong-random-secret
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# --- Database ---
# SQLite (default, no setup) — for production use PostgreSQL
DATABASE_URL=sqlite+aiosqlite:///./edunova.db
# Example Postgres URL:
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/edunova
DATABASE_ECHO=false

# --- LLM Providers ---
LLM_PROVIDER=mock          # openai | gemini | mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
LLM_TEMPERATURE=0.4
LLM_MAX_TOKENS=1500

# --- DeepEval ---
DEEPEVAL_ENABLED=true
DEEPEVAL_THRESHOLD=0.6
DEEPEVAL_MAX_RETRIES=2

# --- Rate limiting ---
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60

# --- Logging ---
LOG_LEVEL=INFO
